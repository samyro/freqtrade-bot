{
  "_comment": "Freqtrade main config. SECRETS live in user_data/config.secrets.json (mounted from k8s Secret, never committed). The entrypoint passes both --config flags so secrets override + extend this file.",

  "max_open_trades": 1,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",

  "_comment_dry_run": "ALWAYS start with dry_run=true. Run 3+ days, validate trade frequency/PnL look sane, THEN flip to false. Going straight to live with a fresh community strategy is how money disappears.",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": false,

  "timeframe": "5m",
  "trading_mode": "spot",
  "margin_mode": "",

  "unfilledtimeout": {
    "entry": 10,
    "exit": 30,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "exchange": {
    "name": "kraken",
    "_comment_keys": "API key + secret loaded from config.secrets.json. Do NOT put real values here.",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": ["ETH/USDT"],
    "pair_blacklist": []
  },

  "pairlists": [{ "method": "StaticPairList" }],

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8090,
    "verbosity": "error",
    "enable_openapi": false,
    "CORS_origins": []
  },

  "bot_name": "freqtrade-eth-kraken",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": { "process_throttle_secs": 5 },

  "db_url": "sqlite:////freqtrade/user_data/db/tradesv3.sqlite",
  "logfile": "/freqtrade/user_data/logs/freqtrade.log"
}
